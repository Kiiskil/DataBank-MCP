{
  "mcpServers": {
    "Databank AI ingest GPU": {
      "command": "podman",
      "args": [
        "run",
        "--rm",
        "-i",
        "--device",
        "/dev/kfd",
        "--device",
        "/dev/dri",
        "--group-add",
        "39",
        "--group-add",
        "105",
        "-e",
        "ZT_DATA_DIR=/data",
        "-e",
        "ZT_TORCH_DEVICE=cuda",
        "-e",
        "ZT_INGEST_REQUIRE_CUDA=1",
        "-e",
        "ZT_EMBED_BATCH=32",
        "-v",
        "${workspaceFolder}/devworkflow:/app/devworkflow:ro,Z",
        "-v",
        "${workspaceFolder}/Databank/AI:/zt/bank:ro,Z",
        "-v",
        "zt-rag-data-databank-ai:/data",
        "localhost/datapankki-mcp:rocm"
      ],
      "env": {}
    },
    "Databank AI": {
      "command": "podman",
      "args": [
        "run",
        "--rm",
        "-i",
        "-e",
        "ANTHROPIC_API_KEY",
        "-e",
        "ZT_DATA_DIR=/data",
        "-e",
        "ZT_ENABLE_QUERY_FALLBACK=1",
        "-e",
        "ZT_ENABLE_CORPUS_AWARE_REWRITE=1",
        "-e",
        "ZT_ENABLE_HYDE=1",
        "-v",
        "${workspaceFolder}/Databank/AI:/zt/bank:ro,Z",
        "-v",
        "zt-rag-data-databank-ai:/data",
        "localhost/datapankki-mcp:latest"
      ],
      "env": {
        "ANTHROPIC_API_KEY": "${env:ANTHROPIC_API_KEY}"
      }
    },
