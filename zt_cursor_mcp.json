{
  "mcpServers": {
    "zt-rag": {
      "command": "podman",
      "args": [
        "run",
        "--rm",
        "-i",
        "-e",
        "ANTHROPIC_API_KEY",
        "-e",
        "ZT_DATA_DIR=/data",
        "-e",
        "ZT_ENABLE_QUERY_FALLBACK=1",
        "-e",
        "ZT_ENABLE_CORPUS_AWARE_REWRITE=1",
        "-e",
        "ZT_ENABLE_HYDE=1",
        "-v",
        "${workspaceFolder}:/workspace:ro,Z",
        "-v",
        "zt-rag-data:/data",
        "localhost/datapankki-mcp:latest"
      ],
      "env": {
        "ANTHROPIC_API_KEY": "${env:ANTHROPIC_API_KEY}"
      }
    }
  }
}
