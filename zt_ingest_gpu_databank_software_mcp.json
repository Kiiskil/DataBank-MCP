{
  "mcpServers": {
    "Databank Software ingest GPU": {
      "command": "podman",
      "args": [
        "run",
        "--rm",
        "-i",
        "--device",
        "/dev/kfd",
        "--device",
        "/dev/dri",
        "--group-add",
        "39",
        "--group-add",
        "105",
        "-e",
        "ZT_DATA_DIR=/data",
        "-e",
        "ZT_TORCH_DEVICE=cuda",
        "-e",
        "ZT_INGEST_REQUIRE_CUDA=1",
        "-e",
        "ZT_EMBED_BATCH=32",
        "-v",
        "${workspaceFolder}/devworkflow:/app/devworkflow:ro,Z",
        "-v",
        "${workspaceFolder}/Databank/Software:/zt/bank:ro,Z",
        "-v",
        "zt-rag-data-databank-software:/data",
        "localhost/datapankki-mcp:rocm"
      ],
      "env": {}
    }
  }
}
