{
  "mcpServers": {
    "zt-rag-ingest-gpu": {
      "command": "podman",
      "args": [
        "run",
        "--rm",
        "-i",
        "--device",
        "/dev/kfd",
        "--device",
        "/dev/dri",
        "--group-add",
        "video",
        "--group-add",
        "render",
        "-e",
        "ZT_DATA_DIR=/data",
        "-e",
        "ZT_TORCH_DEVICE=auto",
        "-e",
        "ZT_EMBED_BATCH=32",
        "-v",
        "/polku/datapankki-mcp/Databank/Software:/zt/bank:ro,Z",
        "-v",
        "zt-rag-data-databank-software:/data",
        "localhost/datapankki-mcp:rocm"
      ],
      "env": {}
    }
  }
}
